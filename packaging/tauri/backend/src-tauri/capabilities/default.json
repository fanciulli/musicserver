{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissions for the Music Server backend launcher window and sidecars",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "binaries/node", "sidecar": true, "args": true },
        { "name": "binaries/mongod", "sidecar": true, "args": true }
      ]
    }
  ]
}
