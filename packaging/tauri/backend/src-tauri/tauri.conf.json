{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Music Server Backend",
  "version": "0.1.0",
  "identifier": "org.musicserver.backend",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "node ../scripts/prepare-sidecars.mjs --app backend --target host"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Music Server Backend",
        "width": 520,
        "height": 420,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Music Server backend (API + MongoDB)",
    "longDescription": "Runs the Music Server backend API and a bundled MongoDB instance. Exposes the API on port 3000. No administrative UI is shown.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/node",
      "binaries/mongod"
    ],
    "resources": [
      "resources/**/*"
    ]
  },
  "plugins": {}
}
