{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Music Server",
  "version": "0.1.0",
  "identifier": "org.musicserver.frontend",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "node ../scripts/prepare-sidecars.mjs --app frontend --target host"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Music Server",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true
      },
      {
        "label": "settings",
        "url": "settings.html",
        "title": "Settings",
        "width": 560,
        "height": 480,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Music",
    "shortDescription": "Music Server admin UI",
    "longDescription": "Desktop application for the Music Server administration UI. Connects to a Music Server backend over the network (default http://localhost:3000).",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/node"
    ],
    "resources": [
      "resources/**/*"
    ]
  },
  "plugins": {}
}
